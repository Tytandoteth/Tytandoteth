# Local development uses SQLite. Point at a file-based DB:
DATABASE_URL="file:./dev.db"

# For production (Supabase / Neon / Railway Postgres), swap the provider in
# prisma/schema.prisma to "postgresql" and use a pooled connection string:
# DATABASE_URL="postgresql://user:password@host:5432/trajectory?schema=public&pgbouncer=true"
# DIRECT_URL="postgresql://user:password@host:5432/trajectory?schema=public"

# Seed user identity (single-operator app; no auth in MVP)
SEED_USER_EMAIL="founder@trajectory.os"
SEED_USER_NAME="Operator"
